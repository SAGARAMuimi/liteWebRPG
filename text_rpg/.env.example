# DB connection string (SQLAlchemy)
#
# Auth backend
# - auto : if DB is PostgreSQL and Neon Auth secrets exist -> neon, else local
# - local: always local users+bcrypt
# - neon : always Neon Auth (email/password via Better Auth HTTP API)
# AUTH_MODE=auto
#
# Neon Auth (Better Auth HTTP API)
# NEON_AUTH_ENABLED=1
# NEON_AUTH_BASE_URL=https://<endpoint>.neonauth.<region>.aws.neon.tech/<dbname>/auth
#   → Neon Console > Auth > Setup で確認できる Base URL をそのままコピー
# NEON_AUTH_API_KEY=  # optional: bearerAuth が要求される場合のみ（Neon Console > Auth > API Keys）
#
# NEON_AUTH_JWKS_URL=https://<endpoint>.neonauth.<region>.aws.neon.tech/<dbname>/auth/.well-known/jwks.json
#   → 推奨: 設定すると JWT をローカル検証（高速・ HTTPコール不要）。未設定時は GET /get-session へ自動フォールバック。
#
# 未使用のキー（コードに利用箇所なし）:
# NEON_AUTH_PUBLIC_KEY → JWKS に包含されるため別途設定不要
# NEON_AUTH_PROJECT_ID → 未使用
#
# SQLite (local dev)
# DATABASE_URL=sqlite:///./text_rpg.db
#
# MySQL (example)
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/DBNAME?charset=utf8mb4
#
# PostgreSQL (recommended for Streamlit Community Cloud)
# Note: This project normalizes postgresql:// to postgresql+pg8000:// automatically.
# Note: libpq/psycopg-style query params like `sslmode=require` or `channel_binding=require`
# are sanitized for pg8000 and won't be passed through as-is.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Optional: operator/privacy display
# OPERATOR_NAME=
# OPERATOR_CONTACT=
# OPERATOR_CONTACT_EMAIL=
# OPERATOR_CONTACT_X=
# OPERATOR_CONTACT_DISCORD=

# Feedback retention (days)
# FEEDBACK_RETENTION_DAYS=365
